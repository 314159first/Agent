FROM maven:3.9-eclipse-temurin-17 AS build

WORKDIR /workspace/AgentX

COPY AgentX/pom.xml ./
COPY AgentX/eclipse-formatter.xml ./
RUN mvn -B -DskipTests dependency:go-offline

COPY AgentX/src ./src
RUN mvn -B -DskipTests clean package

FROM eclipse-temurin:17-jre-jammy

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /workspace/AgentX/target/*.jar /app/app.jar

RUN mkdir -p /app/storage /app/logs /docker/users

EXPOSE 8088

ENV SERVER_PORT=8088
ENV JAVA_OPTS="-Xms512m -Xmx1024m -XX:+UseG1GC"

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=5 \
  CMD curl -fsS http://localhost:8088/api/health >/dev/null || exit 1

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar /app/app.jar"]
