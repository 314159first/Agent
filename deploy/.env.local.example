# AgentX local Docker environment

FRONTEND_PORT=3000
BACKEND_PORT=8088
POSTGRES_PORT=5432
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
ADMINER_PORT=8082

DB_HOST=postgres
DB_PORT=5432
DB_NAME=agentx
DB_USER=postgres
DB_PASSWORD=postgres

RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

SPRING_PROFILES_ACTIVE=dev
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088/api

AGENTX_ADMIN_EMAIL=admin@agentx.local
AGENTX_ADMIN_PASSWORD=admin123
AGENTX_ADMIN_NICKNAME=AgentX Admin

AGENTX_TEST_ENABLED=true
AGENTX_TEST_EMAIL=test@agentx.local
AGENTX_TEST_PASSWORD=test123
AGENTX_TEST_NICKNAME=Test User

JWT_SECRET=local-dev-secret-change-me

# The backend manages user MCP containers through Docker.
# On Docker Desktop for Windows/WSL, the unix socket mount usually works.
AGENTX_CONTAINER_DOCKER_HOST=unix:///var/run/docker.sock
AGENTX_CONTAINER_USER_VOLUME_PATH=/docker/users
AGENTX_CONTAINER_DEFAULT_MCP_IMAGE=ghcr.io/lucky-aeon/mcp-gateway:latest

HIGH_AVAILABILITY_ENABLED=false

JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
