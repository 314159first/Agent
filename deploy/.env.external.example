# AgentX backend/frontend with an external PostgreSQL database.
# Use this file when the database is managed outside docker compose.

FRONTEND_PORT=3000
BACKEND_PORT=8088
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=agentx
DB_USER=agentx
DB_PASSWORD=change-this-db-password

RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=agentx
RABBITMQ_PASSWORD=change-this-rabbitmq-password

SPRING_PROFILES_ACTIVE=prod
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example/api

AGENTX_ADMIN_EMAIL=admin@your-domain.example
AGENTX_ADMIN_PASSWORD=change-this-admin-password
AGENTX_ADMIN_NICKNAME=AgentX Admin
AGENTX_TEST_ENABLED=false

JWT_SECRET=change-this-to-a-long-random-secret

AGENTX_CONTAINER_DOCKER_HOST=unix:///var/run/docker.sock
AGENTX_CONTAINER_USER_VOLUME_PATH=/docker/users
AGENTX_CONTAINER_DEFAULT_MCP_IMAGE=ghcr.io/lucky-aeon/mcp-gateway:latest

HIGH_AVAILABILITY_ENABLED=false
HIGH_AVAILABILITY_GATEWAY_URL=
HIGH_AVAILABILITY_API_KEY=

GITHUB_REPO_NAME=agent-mcp-community
GITHUB_USERNAME=
GITHUB_TOKEN=

MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=

SILICONFLOW_API_KEY=
SILICONFLOW_API_URL_RERANK=

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

PAYMENT_CALLBACK_BASE_URL=https://your-domain.example/api
PAYMENT_SUCCESS_URL=https://your-domain.example/settings/billing?payment=success
PAYMENT_CANCEL_URL=https://your-domain.example/settings/billing?payment=cancel

JAVA_OPTS=-Xms1024m -Xmx2048m -XX:+UseG1GC
